rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Role-based access: Admin check
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "studiosventa@gmail.com" ||
        request.auth.token.email == "thriftbd71@gmail.com" ||
        request.auth.token.email == "mimpy124ahon124@gmail.com"
      );
    }

    // --- Product Rules ---
    match /products/{productId} {
      function isValidProduct(data) {
        return data.keys().hasAll(['name', 'price', 'category', 'sizes', 'stock']) &&
               data.name is string && data.name.size() > 0 && data.name.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               data.category is string &&
               data.sizes is list &&
               data.stock is number && data.stock >= 0;
      }

      allow read: if true; // Public listing
      allow create: if isAdmin() && isValidProduct(incoming()) && incoming().stock >= 0;
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly([
          'name', 'description', 'price', 'category', 'sizes', 'condition', 
          'images', 'stock', 'tags', 'status', 'updatedAt'
        ])
      ) || (
        // System action: Customer purchase reduces stock
        isSignedIn() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['stock', 'status']) &&
        incoming().stock == existing().stock - 1 &&
        incoming().stock >= 0
      );
      allow delete: if isAdmin();
    }

    // --- User Rules ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['email', 'role']) &&
               data.email == request.auth.token.email &&
               data.role in ['user', 'admin'] &&
               (data.role == 'admin' ? (data.email == "studiosventa@gmail.com" || data.email == "thriftbd71@gmail.com") : true);
      }

      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isAdmin();
    }

    // --- Order Rules ---
    match /orders/{orderId} {
      function isValidOrder(data) {
        return data.keys().hasAll(['userId', 'items', 'totalAmount', 'status']) &&
               data.userId == request.auth.uid &&
               data.totalAmount is number && data.totalAmount >= 0 &&
               data.items is list && data.items.size() > 0;
      }

      allow get: if isOwner(existing().userId) || isAdmin();
      allow list: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if isEmailVerified() && isValidOrder(incoming()) && incoming().status == 'pending';
      allow update: if isAdmin() && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
      allow delete: if false; // Orders should be retained
    }

    // --- Admin Collection (for role assignment) ---
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manual setup via console initially
    }

    // --- Connectivity Test ---
    match /test/connection {
      allow read: if true;
    }
  }
}
