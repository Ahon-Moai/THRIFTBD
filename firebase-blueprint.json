{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Storage for clothing items in the shop",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the item" },
        "description": { "type": "string", "description": "Long form description" },
        "price": { "type": "number", "description": "Price in USD" },
        "category": { "type": "string", "description": "e.g., Oversized Tees, Outerwear" },
        "sizes": { "type": "array", "description": "e.g., ['S', 'M', 'L']" },
        "condition": { "type": "string", "description": "e.g., 9/10 (Excellent)" },
        "images": { "type": "array", "description": "List of image URLs" },
        "stock": { "type": "number", "description": "Number of available units" },
        "tags": { "type": "array", "description": "e.g., ['JUST DROPPED', 'RARE FIND', 'ONLY 1 LEFT']" },
        "status": { "type": "string", "description": "active, sold_out" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "sizes", "stock"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer purchase history",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "customerEmail": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "completed", "cancelled"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "totalAmount", "status"]
    },
    "User": {
      "title": "User",
      "description": "User profile and metadata",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all items"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all customer orders"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    }
  }
}
